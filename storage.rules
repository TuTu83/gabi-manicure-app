rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email != null &&
        firestore.exists(/databases/(default)/documents/admin/config) &&
        (request.auth.token.email in firestore.get(/databases/(default)/documents/admin/config).data.emails);
    }

    function isValidImage() {
      return request.resource != null &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType != null &&
        request.resource.contentType.matches('image/.*');
    }

    match /services/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImage();
    }

    match /promotions/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImage();
    }

    match /branding/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImage();
    }
  }
}
