rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email != null &&
        exists(/databases/$(database)/documents/admin/config) &&
        (request.auth.token.email in get(/databases/$(database)/documents/admin/config).data.emails);
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).changedKeys();
    }

    function appointmentBelongsToUser(appointmentId) {
      return appointmentId != null &&
        exists(/databases/$(database)/documents/appointments/$(appointmentId)) &&
        get(/databases/$(database)/documents/appointments/$(appointmentId)).data.userId == request.auth.uid;
    }

    match /admin/config {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /appSettings/public {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promotions/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /payments/{id} {
      allow read, write: if isAdmin();
    }

    match /adminLogs/{id} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (
        isSignedIn() &&
        request.auth.uid == userId &&
        !(changedKeys().hasAny(['vip', 'blocked', 'adminNotes']))
      );
      allow delete: if false;
    }

    match /appointments/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        !(changedKeys().hasAny(['userId', 'userName', 'phoneE164', 'serviceId', 'serviceName', 'durationMinutes', 'priceCents', 'createdAt', 'createdByUserId', 'createdByEmail', 'completedAt'])) &&
        (
          (changedKeys().hasOnly(['notes', 'updatedAt'])) ||
          (changedKeys().hasOnly(['onMyWayAt', 'updatedAt'])) ||
          (changedKeys().hasOnly(['status', 'canceledAt', 'updatedAt']) && request.resource.data.status == 'cancelado') ||
          (changedKeys().hasOnly(['professionalId', 'professionalName', 'startAt', 'endAt', 'status', 'updatedAt']) && request.resource.data.status == 'pendente')
        )
      );
      allow delete: if false;
    }

    match /notifications/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.target == 'cliente' && resource.data.targetUserId == request.auth.uid);
      allow create: if isSignedIn() && (
        (request.resource.data.target == 'cliente' && request.resource.data.targetUserId == request.auth.uid) ||
        (request.resource.data.target == 'admin' && appointmentBelongsToUser(request.resource.data.appointmentId))
      );
      allow update: if isAdmin() || (isSignedIn() && resource.data.target == 'cliente' && resource.data.targetUserId == request.auth.uid);
      allow delete: if false;
    }

    match /reviews/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /waitlist/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
